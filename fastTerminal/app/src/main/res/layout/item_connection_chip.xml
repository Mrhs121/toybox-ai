<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/saved_connection_card"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_margin="4dp"
    android:minWidth="140dp"
    app:cardBackgroundColor="@color/drawer_field_surface"
    app:cardCornerRadius="8dp"
    app:cardElevation="0dp"
    app:strokeColor="@color/drawer_field_stroke"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="40dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingEnd="8dp">

        <TextView
            android:id="@+id/saved_connection_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:maxWidth="180dp"
            android:textColor="@color/text_on_dark"
            android:textSize="13sp" />

        <ImageView
            android:id="@+id/connect_saved_connection_button"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_marginStart="8dp"
            android:contentDescription="@string/connect_action"
            android:src="@drawable/ic_terminal"
            android:tint="@color/text_muted_on_dark" />

        <ImageView
            android:id="@+id/edit_saved_connection_button"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:layout_marginStart="4dp"
            android:contentDescription="@string/edit_connection_action"
            android:src="@drawable/ic_settings"
            android:tint="@color/text_muted_on_dark"
            android:visibility="gone" />

        <ImageView
            android:id="@+id/delete_saved_connection_button"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:layout_marginStart="4dp"
            android:contentDescription="@string/delete_connection_action"
            android:src="@drawable/ic_delete_small"
            android:tint="@color/text_muted_on_dark"
            android:visibility="gone" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
