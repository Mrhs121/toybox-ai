<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/terminal_background"
    android:orientation="vertical"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/saved_connection_section"
            android:textColor="@color/text_muted_on_dark"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textAllCaps="true" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/settings_new_connection"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:minWidth="0dp"
            android:text="@string/new_connection_action"
            android:textColor="@color/text_muted_on_dark" />
    </LinearLayout>

    <TextView
        android:id="@+id/settings_connections_empty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="@string/saved_connections_empty"
        android:textColor="@color/text_muted_on_dark"
        android:textSize="13sp" />

    <com.google.android.flexbox.FlexboxLayout
        android:id="@+id/settings_connections_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        app:flexWrap="wrap"
        app:flexDirection="row"
        app:alignItems="flex_start"
        app:justifyContent="flex_start" />

</LinearLayout>
