<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/terminal_background"
    android:orientation="vertical">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/recent_connections"
                android:textColor="@color/text_muted_on_dark"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textAllCaps="true" />

            <TextView
                android:id="@+id/home_recent_empty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/no_recent_connections"
                android:textColor="@color/text_muted_on_dark"
                android:textSize="13sp" />

            <com.google.android.flexbox.FlexboxLayout
                android:id="@+id/home_recent_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:flexWrap="wrap"
                app:flexDirection="row"
                app:alignItems="flex_start"
                app:justifyContent="flex_start" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="20dp"
                android:background="@color/tab_bar_surface" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/saved_connections_title"
                android:textColor="@color/text_muted_on_dark"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textAllCaps="true" />

            <TextView
                android:id="@+id/home_saved_empty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/saved_connections_empty"
                android:textColor="@color/text_muted_on_dark"
                android:textSize="13sp" />

            <com.google.android.flexbox.FlexboxLayout
                android:id="@+id/home_saved_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:flexWrap="wrap"
                app:flexDirection="row"
                app:alignItems="flex_start"
                app:justifyContent="flex_start" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>
