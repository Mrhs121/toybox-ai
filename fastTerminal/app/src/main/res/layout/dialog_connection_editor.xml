<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="12dp"
    app:cardBackgroundColor="@color/dialog_surface"
    app:cardCornerRadius="28dp"
    app:cardElevation="0dp"
    app:strokeColor="@color/dialog_stroke"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="22dp"
        android:paddingTop="22dp"
        android:paddingEnd="22dp"
        android:paddingBottom="18dp">

        <TextView
            android:id="@+id/dialog_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/text_on_dark"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/password_storage_hint"
            android:textColor="@color/text_muted_on_dark"
            android:textSize="12sp" />

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:hint="@string/host_hint"
            app:boxBackgroundColor="@color/drawer_field_surface"
            app:boxStrokeColor="@color/drawer_field_stroke"
            app:endIconTint="@color/text_muted_on_dark"
            app:hintTextColor="@color/text_muted_on_dark">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/dialog_host_input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:imeOptions="actionNext"
                android:inputType="textUri"
                android:textColor="@color/text_on_dark"
                android:textColorHint="@color/text_muted_on_dark" />
        </com.google.android.material.textfield.TextInputLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="horizontal">

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="@string/port_hint"
                app:boxBackgroundColor="@color/drawer_field_surface"
                app:boxStrokeColor="@color/drawer_field_stroke"
                app:hintTextColor="@color/text_muted_on_dark">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/dialog_port_input"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:imeOptions="actionNext"
                    android:inputType="number"
                    android:textColor="@color/text_on_dark"
                    android:textColorHint="@color/text_muted_on_dark" />
            </com.google.android.material.textfield.TextInputLayout>

            <Space
                android:layout_width="10dp"
                android:layout_height="1dp" />

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="2"
                android:hint="@string/username_hint"
                app:boxBackgroundColor="@color/drawer_field_surface"
                app:boxStrokeColor="@color/drawer_field_stroke"
                app:hintTextColor="@color/text_muted_on_dark">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/dialog_username_input"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:imeOptions="actionNext"
                    android:inputType="textEmailAddress"
                    android:textColor="@color/text_on_dark"
                    android:textColorHint="@color/text_muted_on_dark" />
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:hint="@string/password_hint"
            app:boxBackgroundColor="@color/drawer_field_surface"
            app:boxStrokeColor="@color/drawer_field_stroke"
            app:endIconMode="password_toggle"
            app:endIconTint="@color/text_muted_on_dark"
            app:hintTextColor="@color/text_muted_on_dark">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/dialog_password_input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:imeOptions="actionDone"
                android:inputType="textPassword"
                android:textColor="@color/text_on_dark"
                android:textColorHint="@color/text_muted_on_dark" />
        </com.google.android.material.textfield.TextInputLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:gravity="end"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/dialog_connect_button"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:minWidth="0dp"
                android:text="@string/connect_action"
                android:textColor="@color/text_on_dark"
                app:strokeColor="@color/drawer_field_stroke" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/dialog_cancel_button"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_marginStart="8dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:minWidth="0dp"
                android:text="@string/cancel_action"
                android:textColor="@color/text_muted_on_dark" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/dialog_save_button"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_marginStart="8dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:minWidth="88dp"
                android:text="@string/save_connection_action" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
