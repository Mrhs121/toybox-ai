<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/terminal_tab_card"
    android:layout_width="wrap_content"
    android:layout_height="32dp"
    android:layout_marginEnd="4dp"
    android:background="@color/tab_surface"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingStart="12dp"
    android:paddingEnd="4dp">

    <TextView
        android:id="@+id/terminal_tab_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:ellipsize="end"
        android:maxWidth="220dp"
        android:maxLines="1"
        android:textColor="@color/text_on_dark"
        android:textSize="13sp"
        android:textStyle="bold" />

    <androidx.appcompat.widget.AppCompatImageButton
        android:id="@+id/close_tab_button"
        android:layout_width="18dp"
        android:layout_height="18dp"
        android:layout_marginStart="8dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/close_tab_description"
        android:padding="3dp"
        android:src="@drawable/ic_tab_close"
        android:tint="@color/text_muted_on_dark" />
</LinearLayout>
